      "partOfSpeech": "ot",
      "meaning": "sevgi",
      "examples": [
        {
          "text": "Chin so'g' o'lmas bo'lsa o'lmaydi.",
          "translation": "Chindan sevgi o'lmasa u o'lmaydi",
          "workId": "chin-sogi",
          "workTitle": "Chin so'g'i"
        },
        {
          "text": "So'g' olami qanchalik cheksiz?",
