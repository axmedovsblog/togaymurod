  "words": [
    {
      "id": 1,
      "word": "umr",
      "lemma": "umr",
      "partOfSpeech": "ot",
      "meaning": "hayot, vujud davomiyligi",
      "examples": [
        {
          "text": "Umr yo'lida haqiqatni izla.",
          "translation": "Hayotning yo'lida haqiqatni qidiring",
          "workId": "umr-yolida",
          "workTitle": "Umr yo'lida"
        },
        {
          "text": "Umrim to'liq ishlar bilan.",
          "translation": "Mening hayotim ish-faoliyat bilan to'la",
          "workId": "qanoti-barchasida",
          "workTitle": "Qanoti barchasida"
        }
      ]
    },
    {
      "id": 2,
      "word": "qalb",
      "lemma": "qalb",
      "partOfSpeech": "ot",
      "meaning": "yurak, jon",
      "examples": [
        {
          "text": "Qalbim sevgilining go'zalligidan vanjina.",
          "translation": "Mening yuragim sevgilining go'zalligidan usasi",
          "workId": "chin-sogi",
          "workTitle": "Chin so'g'i"
        },
        {
          "text": "Qalbda nur yo'ritsang, ruh oringan bo'ladi.",
          "translation": "Agar yurakda nur borsa, ruh sa'dga erisadi",
          "workId": "umr-yolida",
          "workTitle": "Umr yo'lida"
        }
      ]
    },
    {
      "id": 3,
      "word": "xazn",
      "lemma": "xazn",
      "partOfSpeech": "ot",
      "meaning": "qayg'u, achinish",
      "examples": [
        {
          "text": "Vatan xazni kim tushunadi?",
          "translation": "Vatan qayg'usi kimni tushunadi?",
          "workId": "umr-yolida",
          "workTitle": "Umr yo'lida"
        },
        {
          "text": "Xazn qo'lda turgan qalam yozadi.",
          "translation": "Qayg'u qolda turgan qalam yozadi",
          "workId": "qanoti-barchasida",
          "workTitle": "Qanoti barchasida"
        }
      ]
    },
    {
      "id": 4,
      "word": "so'g'",
